<div class="lista-page">

    <div class="filtro-bar">
        <form action="/contratos" method="GET" class="filtro-form">
            <div class="filtro-group">
                <label>De</label>
                <input type="date" name="dataInicio" value="{{dataInicio}}" />
            </div>
            <div class="filtro-group">
                <label>Até</label>
                <input type="date" name="dataFim" value="{{dataFim}}" />
            </div>
            <button type="submit" class="btn-filtrar">Filtrar</button>
            <a href="/contratos" class="btn-limpar">Limpar</a>
        </form>
        <a href="/contratos/novo" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Novo Contrato
        </a>
    </div>

    {{#if contratos.length}}
        <div class="contratos-lista">
            {{#each contratos}}
            <div class="contrato-item">
                <div class="contrato-info">
                    <div class="contrato-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                        </svg>
                    </div>
                    <div>
                        <p class="contrato-tipo">{{tipo}}</p>
                        <p class="contrato-data">{{data}}</p>
                    </div>
                </div>
                <a href="/contratos/{{id}}/download" class="btn-download">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7,10 12,15 17,10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Baixar
                </a>
            </div>
            {{/each}}
        </div>
    {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14,2 14,8 20,8"/>
                </svg>
            </div>
            <p>Nenhum contrato encontrado.</p>
            <a href="/contratos/novo" class="btn-ghost">Criar primeiro contrato</a>
        </div>
    {{/if}}

</div>
