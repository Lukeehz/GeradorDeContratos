<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} — Gerador de Contratos</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

    <aside class="sidebar">
        <div class="sidebar__brand">
            <div class="brand-logo">GC</div>
            <span class="brand-name">GerContratos</span>
        </div>

        <nav class="sidebar__nav">
            <a href="/home" class="nav-item nav-item--active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" />
                    <rect x="14" y="3" width="7" height="7" />
                    <rect x="14" y="14" width="7" height="7" />
                    <rect x="3" y="14" width="7" height="7" />
                </svg>
                Dashboard
            </a>
            <a href="/contratos" class="nav-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14,2 14,8 20,8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10,9 9,9 8,9" />
                </svg>
                Contratos
            </a>
        </nav>

        {{#if isModerator}}
        <a href="/usuarios" class="nav-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            Usuários
        </a>
        {{/if}}

                    <a href="/documentos" class="nav-item {{#if isDocumentos}}nav-item--active{{/if}}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="17,8 12,3 7,8" />
                    <line x1="12" y1="3" x2="12" y2="15" />
                </svg>
                Documentos
            </a>

        <div class="sidebar__footer">
            <div class="user-info">
                <div class="user-avatar">{{userInitials}}</div>
                <div class="user-details">
                    <span class="user-name">{{userName}}</span>
                    <span class="user-role">{{#if isModerator}}Admin{{else}}Usuário{{/if}}</span>
                </div>
            </div>
            <a href="/logout" class="btn-logout" title="Sair">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16,17 21,12 16,7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
            </a>



        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <div>
                <h1 class="page-title">{{title}}</h1>
                <p class="page-sub">{{pageSubtitle}}</p>
            </div>
            {{#if messages.error_msg}}
            {{#each messages.error_msg}}
            <div class="flash flash--error"><span class="flash__icon">✕</span><span>{{this}}</span></div>
            {{/each}}
            {{/if}}
            {{#if messages.success_msg}}
            {{#each messages.success_msg}}
            <div class="flash flash--success"><span class="flash__icon">✓</span><span>{{this}}</span></div>
            {{/each}}
            {{/if}}
        </header>

        <div class="content">
            {{{body}}}
        </div>
    </main>

</body>

</html>