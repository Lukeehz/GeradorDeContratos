<div class="lista-page">

    <div class="filtro-bar">
        <span style="font-size:13px;color:var(--muted)">{{documentos.length}} documento(s)</span>
        <a href="/documentos/importar" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17,8 12,3 7,8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            Importar Documento
        </a>
    </div>

    {{#if documentos.length}}
        <div class="contratos-lista">
            {{#each documentos}}
            <div class="contrato-item">
                <div class="contrato-info">
                    <div class="contrato-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                        </svg>
                    </div>
                    <div>
                        <p class="contrato-tipo">{{nomeOriginal}}</p>
                        <p class="contrato-data">
                            {{data}} —
                            {{#if assinado}}
                                <span class="badge-assinado">Assinado</span>
                            {{else}}
                                <span class="badge-pendente">Pendente</span>
                            {{/if}}
                        </p>
                    </div>
                </div>
                <div style="display:flex;gap:8px;align-items:center">
                    {{#unless assinado}}
                    <form action="/documentos/{{id}}/assinar" method="POST">
                        <button type="submit" class="btn-assinar">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 20h9"/>
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                            </svg>
                            Assinar
                        </button>
                    </form>
                    {{/unless}}
                    <a href="/documentos/{{id}}/download" class="btn-download">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7,10 12,15 17,10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        Baixar
                    </a>
                </div>
            </div>
            {{/each}}
        </div>
    {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14,2 14,8 20,8"/>
                </svg>
            </div>
            <p>Nenhum documento importado ainda.</p>
            <a href="/documentos/importar" class="btn-ghost">Importar documento</a>
        </div>
    {{/if}}

</div>
