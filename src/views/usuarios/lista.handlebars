<div class="lista-page">

    <div class="filtro-bar">
        <span style="font-size:13px;color:var(--muted)">{{usuarios.length}} usuário(s) cadastrado(s)</span>
        <a href="/usuarios/novo" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Novo Usuário
        </a>
    </div>

    {{#if usuarios.length}}
        <div class="contratos-lista">
            {{#each usuarios}}
            <div class="contrato-item">
                <div class="contrato-info">
                    <div class="contrato-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <div>
                        <p class="contrato-tipo">{{nomeCompleto}}</p>
                        <p class="contrato-data">{{email}} — <span class="badge-role">{{role}}</span></p>
                    </div>
                </div>
                <form action="/usuarios/{{id}}/deletar" method="POST" onsubmit="return confirm('Remover este usuário?')">
                    <button type="submit" class="btn-deletar">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="3,6 5,6 21,6"/>
                            <path d="M19,6l-1,14a2,2,0,0,1-2,2H8a2,2,0,0,1-2-2L5,6"/>
                            <path d="M10,11v6"/><path d="M14,11v6"/>
                        </svg>
                        Remover
                    </button>
                </form>
            </div>
            {{/each}}
        </div>
    {{else}}
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>
            <p>Nenhum usuário cadastrado.</p>
            <a href="/usuarios/novo" class="btn-ghost">Cadastrar usuário</a>
        </div>
    {{/if}}

</div>
